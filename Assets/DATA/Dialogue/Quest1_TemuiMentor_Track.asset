  voiceClip: {fileID: 8300000, guid: 737bb7c29ee855f4cac063e33ddf9f4c, type: 3}
  objectiveIdToComplete: q1_materi_mentor
  cues:
  - time: 0
    text: '"Banyak orang mengira akuntansi hanyalah soal angka."'
  - time: 4
    text: '"Padahal inti utamanya adalah informasi, bukan sekadar hitungan"'
  - time: 10.565
    text: '"Akuntansi adalah proses mencatat, mengelompokkan, dan menyajikan "'
  - time: 14.8
    text: '"informasi keuangan agar dapat digunakan dalam pengambilan keputusan"'
  - time: 21.785
    text: '"Dengan akuntansi, pemilik usaha tahu apakah bisnisnya untung atau rugi"'
  - time: 28
    text: '"apakah kondisinya sehat, dan bagaimana langkah selanjutnya"'
