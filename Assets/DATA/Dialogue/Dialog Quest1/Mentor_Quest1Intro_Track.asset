  m_Script: {fileID: 11500000, guid: 8a679a0eb95735346b0fc4d1224e7b64, type: 3}
  m_Name: Mentor_Quest1Intro_Track
  m_EditorClassIdentifier: 
  voiceClip: {fileID: 8300000, guid: 2729a372ee2bfb8449d64768ee44419b, type: 3}
  objectiveIdToComplete: 
  cues:
  - time: 0
    text: '"Arahkan tengah kamera ke 3D Objek Mentor untuk berinteraksi, '
  - time: 5.357
    text: dan tekan tombol kamera untuk mematikan kamera, yaitu untuk mengunci UI."
  - time: 11.6
    text: '"Quest pertamamu adalah memahami apa itu akuntansi, mengapa digunakan, '
  - time: 16.934
    text: dan jenis-jenis perusahaan yang akan kamu temui nanti."
  - time: 20.691
    text: '"Jika sudah siap, jangan lupa kerjakan kuisnya ya!"'
