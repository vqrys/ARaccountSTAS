  voiceClip: {fileID: 8300000, guid: b7a02736d3feea4488d4c11492913acd, type: 3}
  cues:
  - time: 0
    text: '"Perusahaan dagang membeli barang lalu menjualnya'
  - time: 4.889
    text: kembali tanpa mengubah bentuknya."
  - time: 8.775
    text: '"Contohnya toko alat tulis, minimarket, grosir, toko baju."'
  - time: 16.415
    text: '"Ada persediaan barang dan ada istilah Harga Pokok Penjualan."'
  - time: 22.63
    text: '"Fokusnya adalah kegiatan beli dan jual barang dagangan."'
