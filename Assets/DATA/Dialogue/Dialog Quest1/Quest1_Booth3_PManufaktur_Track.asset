  voiceClip: {fileID: 8300000, guid: a1c405b2d5a3b8a468cd4d921b3abeb7, type: 3}
  cues:
  - time: 0
    text: '"Perusahaan manufaktur mengolah bahan baku menjadi barang jadi."'
  - time: 5.545
    text: '"Contohnya pabrik roti, pabrik sepatu, pabrik elektronik."'
  - time: 13.155
    text: "\"Ada proses produksi: bahan baku \u2192 barang dalam proses \u2192 barang
      jadi.\""
  - time: 22
    text: '"Akuntansi manufaktur lebih kompleks karena melibatkan biaya produksi."'
