  voiceClip: {fileID: 8300000, guid: 40e7504bbc2bb6444b38748433146262, type: 3}
  objectiveIdToComplete: 
  cues:
  - time: 0
    text: "\u201CAset adalah sumber daya yang dimiliki perusahaan. \r\n"
  - time: 3.997
    text: 'Kewajiban adalah kewajiban atau utang perusahaan kepada pihak lain. '
  - time: 10.118
    text: "Ekuitas adalah hak pemilik terhadap aset perusahaan.\u201D"
  - time: 15.4
    text: '"Jika perusahaan memiliki aset, pasti sumber perolehannya'
  - time: 19.9
    text: 'berasal dari dua tempat yaitu: '
  - time: 23.046
    text: "dari pinjaman (kewajiban) atau dari pemilik (ekuitas).\u201D "
  - time: 29.597
    text: "\u201CIngat: persamaan ini harus selalu seimbang."
  - time: 34.2
    text: "Jika satu sisi berubah, sisi lainnya juga harus berubah.\u201D "
