  voiceClip: {fileID: 8300000, guid: 0e0a47c487880f545abac3b43c3e29e3, type: 3}
  objectiveIdToComplete: 
  cues:
  - time: 0
    text: "\u201CSelamat. Sekarang kamu sudah memahami bagaimana akun diklasifikasikan.\u201D "
  - time: 5.798
    text: "\u201CNamun dalam praktiknya, nilai aset, kewajiban, dan ekuitas tidak
      tetap. "
  - time: 12
    text: "Mereka akan berubah setiap kali terjadi transaksi.\u201D "
  - time: 15.6
    text: "\u201CYang harus kamu jaga adalah keseimbangan, meskipun angkanya berubah.\u201D"
