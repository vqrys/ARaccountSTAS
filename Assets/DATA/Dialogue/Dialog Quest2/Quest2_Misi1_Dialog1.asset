  cues:
  - time: 0
    text: "\u201CSelamat datang di pelatihan lanjutan. \r\nDi quest ini, "
  - time: 4.252
    text: "kamu akan mempelajari Persamaan Dasar Akuntansi.\u201D"
  - time: 8.432
    text: "\r\u201CPersamaan dasar akuntansi adalah pondasi utama "
  - time: 12.08
    text: dalam pencatatan keuangan."
  - time: 14.496
    text: '"Semua transaksi yang terjadi dalam perusahaan '
  - time: 17.591
    text: "harus selalu menjaga keseimbangan ini.\u201D "
