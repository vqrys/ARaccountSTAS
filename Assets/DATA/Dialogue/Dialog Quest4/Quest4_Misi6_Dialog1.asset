  objectiveIdToComplete: q4_m6_materi
  cues:
  - time: 0
    text: "\u201CPerusahaan jasa biasanya membutuhkan <color=orange>perlengkapan</color>
      seperti kertas, "
  - time: 3.955
    text: "tinta printer, alat tulis, dan kebutuhan operasional kecil lainnya.\u201D"
  - time: 8.812
    text: "\u201CKarena perlengkapan masih akan <color=orange>dipakai di masa depan</color>, "
  - time: 11.787
    text: 'ia dicatat sebagai <color=orange>ASET</color>, bukan beban. '
  - time: 14.682
    text: "Beban baru terjadi ketika perlengkapan dipakai, bukan saat dibeli.\u201D"
