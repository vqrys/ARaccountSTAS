  objectiveIdToComplete: tut_pendahuluan
  cues:
  - time: 0
    text: '"Selamat datang di Academy of Accountancy!"'
  - time: 3.528
    text: '"Aku akan mengajari kamu Akuntansi dengan cara yang seru '
  - time: 7.352
    text: menggunakan Realitas Tertambah (AR)."
  - time: 9.9
    text: '"Perkenalkan, aku adalah mentormu. Aku akan menemanimu dari awal '
  - time: 15.3
    text: sampai kamu jadi ahli laporan keuangan!"
  - time: 18.765
    text: 'Untuk sekarang, coba lihat menu di layar. '
  - time: 21.9
    text: Mari kita mulai perjalananmu dengan menekan tombol Quest 1!
